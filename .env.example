# Copy to .env.local and fill in. Full explanations: docs/ARCHITECTURE.md §7

# ── Required ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# Postgres via pgBouncer (port 6543) — what the app uses at runtime
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<pooler-host>:6543/postgres
# Direct Postgres (port 5432) — used by `prisma db push` only
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@<db-host>:5432/postgres
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Optional (features degrade gracefully without them) ──────────────────────
# Real AI generation + grading (unset = mock generation, manual grading)
ANTHROPIC_API_KEY=
# Override the default model (claude-sonnet-5)
# AI_MODEL=
# Invite email sending
RESEND_API_KEY=
# Hosted Judge0 for coding-question execution (unset = manual grading)
# JUDGE0_API_URL=
# JUDGE0_API_KEY=
# Protects /api/cron/* (Vercel sends it automatically when set)
# CRON_SECRET=
# Shared secret for the internal psychometrics Python function
# PSYCHOMETRICS_SECRET=
# Super Admin panel cost estimates
# AI_COST_PER_CALL=0.02
# JUDGE0_COST_PER_SUBMISSION=0.0005
