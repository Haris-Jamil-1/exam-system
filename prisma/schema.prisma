generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  admin
  teacher
  student
}

enum ExamStatus {
  draft
  scheduled
  live
  completed
}

enum ApprovalStatus {
  not_submitted
  pending
  approved
  rejected
}

enum QuestionType {
  mcq
  mrq
  true_false
  short_answer
  essay
  fill_blank
  matching
  ordering
  coding
  file_upload
}

enum Difficulty {
  easy
  medium
  hard
}

enum ItemStatus {
  draft
  review
  approved
  archived
}

enum AttemptStatus {
  in_progress
  submitted
  auto_submitted
}

enum ViolationType {
  tab_switch
  window_blur
  fullscreen_exit
  no_face
  multiple_faces
  audio_detected
  phone_detected
  gaze_away
  prohibited_object
}

enum ViolationSeverity {
  low
  medium
  high
}

enum BloomsLevel {
  Remember
  Understand
  Apply
  Analyze
  Evaluate
  Create
}

enum LearningDomain {
  Knowledge
  Skill
  Values
}

enum ItemBankLevel {
  institutional
  personal
}

enum ItemBankPermissionRole {
  owner
  editor
  viewer
}

enum ClassInviteStatus {
  pending
  accepted
  expired
}

// ── Models ───────────────────────────────────────────────────────────────────

model Institution {
  id        String   @id @default(cuid())
  name      String
  domain    String
  joinCode  String   @unique @default(cuid())
  createdAt DateTime @default(now())
  // Phase 3 decision 5: per-institution monthly AI-call ceiling (generation +
  // grading), hard stop at quota. Usage resets when aiUsageMonth rolls over.
  aiMonthlyQuota Int    @default(1000)
  aiUsageCount   Int    @default(0)
  aiUsageMonth   String @default("")
  // Follow-up task 1: hosted Judge0 is pay-per-use — same quota pattern, one
  // count per test-case submission. Shares aiUsageMonth for the rollover.
  judgeMonthlyQuota Int @default(1000)
  judgeUsageCount   Int @default(0)
  // Follow-up task 3: soft suspension — blocks access for every user of the
  // institution, no hard delete.
  suspendedAt       DateTime?

  users     User[]
  exams     Exam[]
  items     Item[]
  courses   Course[]
  itemBanks ItemBank[]
  classes   Class[]
}

model User {
  id            String   @id @default(cuid())
  supabaseId    String   @unique
  name          String
  email         String   @unique
  role          Role
  department    String?
  avatarUrl     String?
  institutionId String
  createdAt     DateTime @default(now())
  // Follow-up task 3: platform-level Super Admin — deliberately NOT a Role
  // enum value (own auth gate, not reachable via institution RBAC). Set
  // manually via SQL. suspendedAt = soft suspension (blocks access, no delete).
  isSuperAdmin  Boolean   @default(false)
  suspendedAt   DateTime?

  institution         Institution      @relation(fields: [institutionId], references: [id])
  exams               Exam[]           @relation("ExamTeacher")
  items               Item[]           @relation("ItemAuthor")
  attempts            ExamAttempt[]
  violations          Violation[]
  enrollments         ExamEnrollment[]
  invitesSent         InviteToken[]    @relation("InvitedBy")
  teacherStudents     TeacherStudent[] @relation("TeacherStudents")
  studentTeachers     TeacherStudent[] @relation("StudentTeachers")
  itemBankAccess      ItemBankAccess[] @relation("ItemBankAccessUser")
  itemBankAccessGrant ItemBankAccess[] @relation("ItemBankAccessAssignedBy")
  monitorDirectives   MonitorDirective[]
  generationJobs      GenerationJob[]
  answerGradings      AnswerGrading[] @relation("AnswerGrader")
  classes             Class[]           @relation("ClassTeacher")
  classInvitesSent    ClassInvite[]     @relation("ClassInvitedBy")
  classEnrollments    ClassEnrollment[] @relation("ClassEnrollmentStudent")

  @@index([institutionId])
  @@index([institutionId, role])
}

model TeacherStudent {
  id        String   @id @default(cuid())
  teacherId String
  studentId String
  createdAt DateTime @default(now())

  teacher User @relation("TeacherStudents", fields: [teacherId], references: [id], onDelete: Cascade)
  student User @relation("StudentTeachers", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([teacherId, studentId])
  @@index([teacherId])
  @@index([studentId])
}

model InviteToken {
  id            String    @id @default(cuid())
  token         String    @unique @default(cuid())
  email         String
  role          Role
  institutionId String
  invitedById   String
  expiresAt     DateTime
  acceptedAt    DateTime?
  createdAt     DateTime  @default(now())

  invitedBy User @relation("InvitedBy", fields: [invitedById], references: [id])
}

model Class {
  id            String    @id @default(cuid())
  name          String
  teacherId     String
  institutionId String
  createdAt     DateTime  @default(now())
  archivedAt    DateTime?

  teacher     User              @relation("ClassTeacher", fields: [teacherId], references: [id])
  institution Institution       @relation(fields: [institutionId], references: [id])
  invites     ClassInvite[]
  enrollments ClassEnrollment[]

  @@index([teacherId])
  @@index([institutionId])
}

model ClassInvite {
  id          String            @id @default(cuid())
  classId     String
  email       String
  status      ClassInviteStatus @default(pending)
  token       String            @unique @default(cuid())
  invitedById String
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime          @default(now())

  class     Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  invitedBy User  @relation("ClassInvitedBy", fields: [invitedById], references: [id])

  @@index([classId])
  @@index([email])
}

model ClassEnrollment {
  id        String   @id @default(cuid())
  classId   String
  studentId String
  joinedAt  DateTime @default(now())

  class   Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  student User  @relation("ClassEnrollmentStudent", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classId, studentId])
  @@index([studentId])
}

// Rate-limit log for password-reset requests (per email — spec asks for
// per-email throttling only, not per-IP). Checked/appended by
// POST /api/auth/forgot-password before calling Supabase.
model PasswordResetAttempt {
  id        String   @id @default(cuid())
  email     String
  createdAt DateTime @default(now())

  @@index([email, createdAt])
}

model Exam {
  id                 String         @id @default(cuid())
  title              String
  subject            String
  duration           Int
  totalMarks         Int
  passingMarks       Int
  status             ExamStatus     @default(draft)
  approvalStatus     ApprovalStatus @default(not_submitted)
  startTime          DateTime
  endTime            DateTime
  maxViolations      Int            @default(3)
  settings           Json
  resultsPublishedAt DateTime?
  instructions       String?
  isProctoringEnabled Boolean       @default(true)
  institutionId      String
  teacherId          String
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  institution Institution      @relation(fields: [institutionId], references: [id])
  teacher     User             @relation("ExamTeacher", fields: [teacherId], references: [id])
  questions   Question[]
  attempts    ExamAttempt[]
  enrollments ExamEnrollment[]
  violations  Violation[]
  sections    ExamSection[]

  @@index([institutionId])
  @@index([institutionId, teacherId])
  @@index([institutionId, approvalStatus])
  @@index([institutionId, status])
  @@index([teacherId])
}

model ExamEnrollment {
  id         String   @id @default(cuid())
  examId     String
  studentId  String
  enrolledAt DateTime @default(now())

  exam    Exam @relation(fields: [examId], references: [id], onDelete: Cascade)
  student User @relation(fields: [studentId], references: [id])

  @@unique([examId, studentId])
  @@index([studentId])
}

model Question {
  id                  String       @id @default(cuid())
  examId              String
  // Set only for a per-attempt, JIT stratified-pooled question (drawn randomly from an Item
  // pool when that one student's attempt was created) — null for the normal fixed/shared
  // question set every student of a non-pooled exam sees identically. A pooled exam's
  // Question rows all share examId but are privately scoped to one attempt each; every query
  // that lists "this exam's questions" for display/scoring MUST filter accordingly (see
  // getQuestions/getQuestionsForAttempt in lib/data/questions.ts) or it will mix together
  // every student's individually-drawn questions.
  attemptId           String?
  // Null = this exam has no sections (the default, fully backward-compatible — every existing
  // exam and every non-sectioned new exam behaves exactly as before). Set = this question
  // belongs to that section; a sectioned exam's questions are always grouped this way.
  sectionId           String?
  type                QuestionType
  stem                String
  marks               Int          @default(1)
  difficulty          Difficulty   @default(medium)
  order               Int          @default(0)
  required            Boolean      @default(false)
  explanation         String?
  correctAnswer       Json?
  learningObjectiveId String?
  codeLanguage        String?
  starterCode         String?
  testCases           Json?
  allowedFileTypes    String[]
  maxFileSizeMB       Int?
  timeLimitSeconds    Int?
  // Phase 3 (doc 03): grading rubric for essay/coding — criteria array
  // [{name, description, maxPoints}]. No rubric = no AI grading (manual only).
  // gradingWeights (coding): {testWeight, qualityWeight}, default 70/30.
  rubric              Json?
  gradingWeights      Json?
  // Phase 3 (doc 05): durable link back to the bank Item this question was
  // materialized from — item-level psychometrics aggregate across
  // administrations through this. Null = authored directly on the exam
  // (exam-scoped stats only) or created before Phase 3 (stated limitation).
  sourceItemId        String?
  createdAt           DateTime     @default(now())

  exam              Exam               @relation(fields: [examId], references: [id], onDelete: Cascade)
  attempt           ExamAttempt?       @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  section           ExamSection?       @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  learningObjective LearningObjective? @relation(fields: [learningObjectiveId], references: [id])
  options           Option[]
  answers           Answer[]

  @@index([examId, attemptId])
  @@index([sectionId])
}

model ExamSection {
  id               String   @id @default(cuid())
  examId           String
  title            String
  instructions     String?
  // Null = no isolated timer for this section (governed only by the overall exam deadline).
  durationMinutes  Int?
  orderIndex       Int      @default(0)
  // Percentage of the exam's total grade this section contributes, e.g. 40 for 40%.
  sectionWeight    Float    @default(0)
  // Minimum scaled score (0-100) required to "pass" this section — independent of the overall
  // composite score. If set and missed, the whole exam attempt is flagged Failed regardless of
  // total score (see computeSectionScores in lib/scoring.ts).
  passingThreshold Int?
  createdAt        DateTime @default(now())

  exam            Exam             @relation(fields: [examId], references: [id], onDelete: Cascade)
  questions       Question[]
  sectionAttempts SectionAttempt[]

  @@index([examId])
}

model SectionAttempt {
  id              String        @id @default(cuid())
  attemptId       String
  sectionId       String
  status          AttemptStatus @default(in_progress)
  // Set only once the student clicks "Start Section" — the section's own isolated timer is
  // seeded from this, not from when the parent ExamAttempt was created.
  startedAt       DateTime?
  submittedAt     DateTime?
  score           Float?
  totalMarks      Int?
  scorePercentage Float?
  passed          Boolean?
  createdAt       DateTime      @default(now())

  attempt ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  section ExamSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, sectionId])
  @@index([attemptId])
}

model Option {
  id         String  @id @default(cuid())
  questionId String
  text       String
  isCorrect  Boolean @default(false)
  order      Int     @default(0)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model Item {
  id                  String       @id @default(cuid())
  type                QuestionType
  stem                String
  marks               Int          @default(1)
  difficulty          Difficulty   @default(medium)
  order               Int          @default(0)
  required            Boolean      @default(false)
  explanation         String?
  correctAnswer       Json?
  status              ItemStatus   @default(draft)
  usageCount          Int          @default(0)
  tags                String[]
  codeLanguage        String?
  starterCode         String?
  testCases           Json?
  allowedFileTypes    String[]
  maxFileSizeMB       Int?
  timeLimitSeconds    Int?
  rubric              Json?
  gradingWeights      Json?
  facilityIndex       Float?
  discriminationIndex Float?
  version             Int          @default(1)
  previousVersionId   String?
  institutionId       String
  authorId            String
  learningObjectiveId String?
  bankId              String?
  // Phase 3 (doc 02): provenance for AI-generated items. null generationJobId =
  // human-authored (backward compatible). reviewedById = who approved/rejected.
  generationJobId     String?
  aiGenerated         Boolean      @default(false)
  reviewedById        String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  institution       Institution        @relation(fields: [institutionId], references: [id])
  author            User               @relation("ItemAuthor", fields: [authorId], references: [id])
  learningObjective LearningObjective? @relation(fields: [learningObjectiveId], references: [id])
  bank              ItemBank?          @relation(fields: [bankId], references: [id])
  generationJob     GenerationJob?     @relation(fields: [generationJobId], references: [id])
  options           ItemOption[]

  @@index([bankId])
  @@index([bankId, learningObjectiveId])
  @@index([generationJobId])
}

// Async AI item-generation job (Phase 3, doc 02): the row IS the durability —
// the runtime (Vercel background work, decision 6) is disposable. Carries the
// full audit/cost trail: what was asked, which model, what it cost.
enum GenerationJobStatus {
  queued
  running
  succeeded
  partial
  failed
}

model GenerationJob {
  id                  String              @id @default(cuid())
  institutionId       String
  requestedById       String
  itemBankId          String
  learningObjectiveId String?
  status              GenerationJobStatus @default(queued)
  requestedCount      Int
  producedCount       Int                 @default(0)
  promptParams        Json
  model               String?
  inputTokens         Int?
  outputTokens        Int?
  error               String?
  createdAt           DateTime            @default(now())
  startedAt           DateTime?
  finishedAt          DateTime?

  requestedBy User     @relation(fields: [requestedById], references: [id])
  bank        ItemBank @relation(fields: [itemBankId], references: [id], onDelete: Cascade)
  items       Item[]

  @@index([itemBankId, status])
  @@index([institutionId, createdAt])
}

model ItemBank {
  id            String        @id @default(cuid())
  name          String
  description   String?
  bankLevel     ItemBankLevel
  // INSTITUTIONAL: Institution.id. PERSONAL: the creating User.id.
  ownerId       String
  institutionId String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  institution Institution      @relation(fields: [institutionId], references: [id])
  items       Item[]
  access      ItemBankAccess[]
  generationJobs GenerationJob[]

  @@index([institutionId])
  @@index([institutionId, bankLevel])
  @@index([institutionId, ownerId])
}

model ItemBankAccess {
  id             String                  @id @default(cuid())
  bankId         String
  userId         String
  permissionRole ItemBankPermissionRole
  assignedById   String
  createdAt      DateTime                @default(now())

  bank       ItemBank @relation(fields: [bankId], references: [id], onDelete: Cascade)
  user       User     @relation("ItemBankAccessUser", fields: [userId], references: [id], onDelete: Cascade)
  assignedBy User     @relation("ItemBankAccessAssignedBy", fields: [assignedById], references: [id])

  @@unique([bankId, userId])
  @@index([userId])
  @@index([bankId])
}

model ItemOption {
  id        String  @id @default(cuid())
  itemId    String
  text      String
  isCorrect Boolean @default(false)
  order     Int     @default(0)

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model ExamAttempt {
  id                String        @id @default(cuid())
  examId            String
  studentId         String
  status            AttemptStatus @default(in_progress)
  startedAt         DateTime      @default(now())
  submittedAt       DateTime?
  score             Float?
  totalMarks        Int?
  scorePercentage   Float?
  trustScore        Int           @default(100)
  violationCount    Int           @default(0)
  biometricVerified Boolean       @default(false)
  createdAt         DateTime      @default(now())

  exam             Exam             @relation(fields: [examId], references: [id])
  student          User             @relation(fields: [studentId], references: [id])
  answers          Answer[]
  violations       Violation[]
  pooledQuestions  Question[]
  sectionAttempts  SectionAttempt[]
  heartbeat        ProctoringHeartbeat?
  directives       MonitorDirective[]

  @@unique([examId, studentId])
  @@index([studentId])
  @@index([examId])
}

model Answer {
  id           String    @id @default(cuid())
  attemptId    String
  questionId   String
  response     Json?
  fileUrl      String?
  isCorrect    Boolean?
  marksAwarded Float?
  gradedAt     DateTime?
  createdAt    DateTime  @default(now())
  // Null = deterministic-scored (all pre-Phase-3 rows and every non-essay/
  // coding answer). The essay/coding grading state machine lives here.
  gradingStatus GradingStatus?

  attempt  ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [questionId], references: [id])
  gradings AnswerGrading[]

  @@unique([attemptId, questionId])
}

// AI-assisted grading (Phase 3, doc 03). Append-only log — one row per grading
// event on an answer. The AI's suggestion, the teacher's confirmation or
// override, and the exact rubric snapshot each was made under together form
// the dispute trail: for any published mark you can replay what standard was
// applied, what the AI said, and who changed what. Answer.marksAwarded is only
// ever set by teacher rows (decision 4: no auto-confirm, ever).
enum GradingStatus {
  pending_ai
  ai_suggested
  confirmed
  overridden
}

enum GradingKind {
  ai_suggestion
  teacher_confirmation
  teacher_override
}

model AnswerGrading {
  id              String      @id @default(cuid())
  answerId        String
  attemptId       String
  kind            GradingKind
  // Exact rubric this event was made under (criteria array) — the versioned
  // standard, snapshotted so later rubric edits can't rewrite history.
  rubricSnapshot  Json?
  criterionScores Json?
  totalScore      Float
  feedback        String?
  rationale       Json?
  executionResult Json? // coding: per-test pass/fail, stderr, limits
  model           String?
  inputTokens     Int?
  outputTokens    Int?
  gradedById      String?
  createdAt       DateTime    @default(now())

  answer   Answer @relation(fields: [answerId], references: [id], onDelete: Cascade)
  gradedBy User?  @relation("AnswerGrader", fields: [gradedById], references: [id])

  @@index([answerId, createdAt])
  @@index([attemptId])
}

// Follow-up task 1: per-call attribution for the hosted (pay-per-use) Judge0
// API — Judge0 has no tenant concept, so this log is the only way to attribute
// cost per institution. One row per coding-answer grading event.
model JudgeUsageLog {
  id             String   @id @default(cuid())
  institutionId  String
  examAttemptId  String
  questionId     String
  // submissions actually sent (test cases run) — the billing unit
  submissionCount Int     @default(0)
  status         String // executed | unavailable | quota_exceeded | error
  submittedAt    DateTime @default(now())

  @@index([institutionId, submittedAt])
}

model Violation {
  id            String            @id @default(cuid())
  attemptId     String
  studentId     String
  examId        String
  type          ViolationType
  severity      ViolationSeverity @default(low)
  description   String
  screenshotUrl String?
  metadata      Json?
  timestamp     DateTime          @default(now())
  // Phase 3 unified proctoring events: detector confidence (1.0 for deterministic
  // signals), episode end (null = instantaneous or still ongoing at flush), and a
  // per-attempt monotonic counter so the server can detect suppressed/lost batches.
  confidence    Float?
  endedAt       DateTime?
  clientSeq     Int?

  attempt ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  student User        @relation(fields: [studentId], references: [id])
  exam    Exam        @relation(fields: [examId], references: [id])

  @@index([examId])
  @@index([studentId])
  @@index([examId, severity])
}

// Teacher → student monitor actions (Phase 3, doc 04): on-demand snapshot
// pulls, warning banners, force-submit. Append-only — every teacher action on
// a live attempt is audited (who asked, when, of whom). Students receive
// pending directives over Realtime (RLS-scoped to their own attempt) with a
// polling fallback.
enum DirectiveKind {
  snapshot
  warning
  force_submit
}

enum DirectiveStatus {
  pending
  fulfilled
  failed
}

model MonitorDirective {
  id            String          @id @default(cuid())
  attemptId     String
  kind          DirectiveKind
  message       String?
  status        DirectiveStatus @default(pending)
  resultPath    String? // snapshot: private storage path of the captured frame
  requestedById String
  createdAt     DateTime        @default(now())
  fulfilledAt   DateTime?

  attempt     ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  requestedBy User        @relation(fields: [requestedById], references: [id])

  @@index([attemptId, status])
}

// One upserted row per attempt (not an append log) — liveness signal for the
// proctoring runtime. A stale lastSeenAt on an in_progress attempt means the
// detectors died or were suppressed; surfaced on the teacher monitor.
model ProctoringHeartbeat {
  id         String   @id @default(cuid())
  attemptId  String   @unique
  lastSeq    Int      @default(0)
  lastSeenAt DateTime @default(now())
  metadata   Json?

  attempt ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
}

// Psychometrics (Phase 3, doc 05): versioned per-administration item stats.
// One row per (item, exam administration), upserted by the Python stats
// service on recompute (idempotent — regrades just overwrite the same
// administration's row). Item.facilityIndex/discriminationIndex hold the
// response-count-weighted rolling aggregate across administrations.
model ItemAdministrationStat {
  id              String   @id @default(cuid())
  itemId          String
  examId          String
  institutionId   String
  computeRunId    String
  nResponses      Int
  facilityIndex   Float?
  discrimination  Float? // corrected point-biserial (item vs total-minus-item)
  distractorStats Json?
  // Decision 10: stats from <10 responses are stored but display-gated;
  // <30 responses render as "low confidence" for discrimination.
  insufficientN   Boolean  @default(false)
  computedAt      DateTime @default(now())

  @@unique([itemId, examId])
  @@index([examId])
  @@index([itemId])
}

model ExamReliabilityStat {
  id            String   @id @default(cuid())
  examId        String   @unique
  institutionId String
  computeRunId  String
  cronbachAlpha Float?
  kr20          Float?
  nStudents     Int
  nItems        Int
  sectionAlphas Json?
  computedAt    DateTime @default(now())
}

model Course {
  id            String   @id @default(cuid())
  code          String
  title         String
  institutionId String
  createdAt     DateTime @default(now())

  institution Institution @relation(fields: [institutionId], references: [id])
  topics      Topic[]

  @@unique([institutionId, code])
}

model Topic {
  id        String   @id @default(cuid())
  courseId  String
  title     String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  course             Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  learningObjectives LearningObjective[]
}

model LearningObjective {
  id             String         @id @default(cuid())
  topicId        String
  code           String?
  text           String
  bloomsLevel    BloomsLevel
  learningDomain LearningDomain
  createdAt      DateTime       @default(now())

  topic     Topic      @relation(fields: [topicId], references: [id], onDelete: Cascade)
  questions Question[]
  items     Item[]
}
